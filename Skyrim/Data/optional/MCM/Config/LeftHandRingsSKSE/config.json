{
  "$schema": "https://raw.githubusercontent.com/Exit-9B/MCM-Helper/main/docs/config.schema.json",
  "modName": "LeftHandRingsSKSE",
  "displayName": "Left Hand Rings",
  "minMcmVersion": 13,
  "customContent": {
    "source": "LeftHandRingsSKSE/logo.dds",
    "x": 0,
    "y": 11
  },
  "pages": [
    {
      "pageDisplayName": "General",
      "content": [
        {
          "type": "hiddenToggle",
          "text": "Fixed strength selected",
          "groupControl": 1,
          "valueOptions": {
            "sourceType": "PropertyValueBool",
            "propertyName": "bFixedStrengthSelected"
          }
        },
        {
          "type": "hiddenToggle",
          "text": "Cosmetic extra rings selected",
          "groupControl": 2,
          "valueOptions": {
            "sourceType": "PropertyValueBool",
            "propertyName": "bCosmeticExtraRingsSelected"
          }
        },
        {
          "type": "hiddenToggle",
          "text": "Controller input selected",
          "groupControl": 3,
          "valueOptions": {
            "sourceType": "PropertyValueBool",
            "propertyName": "bControllerInputSelected"
          }
        },
        {
          "id": "iExtraRingMode:General",
          "text": "Extra ring mode",
          "type": "enum",
          "help": "Functional applies normal ring enchantments and scripts. Cosmetic only shows the ring model. Applies only to extra rings. The vanilla right-hand index finger ring is unaffected.",
          "valueOptions": {
            "sourceType": "ModSettingInt",
            "defaultValue": 0,
            "options": [
              "Functional",
              "Cosmetic"
            ]
          }
        },
        {
          "id": "iEnchantmentStrengthMode:General",
          "text": "Enchantment strength",
          "type": "enum",
          "groupCondition": {
            "NOT": 2
          },
          "groupBehavior": "disable",
          "help": "Full keeps normal strength. Fixed uses the chosen strength. Split divides 100% evenly between counted rings. Only equipped rings with at least one non-zero-magnitude enchantment effect are counted, including the vanilla right-hand index finger.",
          "valueOptions": {
            "sourceType": "ModSettingInt",
            "defaultValue": 0,
            "options": [
              "Full strength",
              "Fixed strength",
              "Split strength"
            ]
          }
        },
        {
          "id": "iFixedEnchantmentStrengthPercent:General",
          "text": "Fixed strength",
          "type": "slider",
          "groupCondition": {
            "AND": [
              1,
              {
                "NOT": 2
              }
            ]
          },
          "groupBehavior": "hide",
          "help": "Used by Fixed strength mode. Only equipped rings with at least one non-zero-magnitude enchantment effect are counted, including the vanilla right-hand index finger.",
          "valueOptions": {
            "sourceType": "ModSettingInt",
            "defaultValue": 50,
            "min": 5,
            "max": 100,
            "step": 5,
            "formatString": "{0}%"
          }
        },
        {
          "id": "bAlwaysChooseFinger:General",
          "text": "Always choose finger",
          "type": "toggle",
          "help": "Always show the finger selection menu whenever you use Equip or Left Equip on a ring without pressing a modifier key.",
          "valueOptions": {
            "sourceType": "ModSettingBool",
            "defaultValue": false
          }
        },
        {
          "id": "iFingerSelectModifierKey:General",
          "text": "Finger select modifier",
          "type": "keymap",
          "ignoreConflicts": true,
          "groupCondition": {
            "NOT": 3
          },
          "groupBehavior": "skip",
          "help": "Hold this key while equipping a ring to choose a finger.",
          "valueOptions": {
            "sourceType": "ModSettingInt",
            "defaultValue": 42
          }
        },
        {
          "id": "iFingerSelectModifierButton:General",
          "text": "Finger select modifier",
          "type": "keymap",
          "ignoreConflicts": true,
          "groupCondition": 3,
          "groupBehavior": "skip",
          "help": "Hold this button while equipping a ring to choose a finger.",
          "valueOptions": {
            "sourceType": "ModSettingInt",
            "defaultValue": 274
          }
        }
      ]
    }
  ]
}
