{
  "$schema": "https://raw.githubusercontent.com/Exit-9B/MCM-Helper/main/docs/config.schema.json",
  "modName": "LeftHandRingsSKSE",
  "displayName": "Left Hand Rings",
  "minMcmVersion": 13,
  "customContent": {
    "source": "LeftHandRingsSKSE/logo.dds",
    "x": 0,
    "y": 11
  },
  "pages": [
    {
      "pageDisplayName": "General",
      "content": [
        {
          "type": "hiddenToggle",
          "text": "Fixed strength selected",
          "groupControl": 1,
          "valueOptions": {
            "sourceType": "PropertyValueBool",
            "propertyName": "bFixedStrengthSelected"
          }
        },
        {
          "id": "iEnchantmentStrengthMode:General",
          "text": "Enchantment strength",
          "type": "enum",
          "help": "Full keeps normal strength. Fixed uses the chosen strength. Split divides 100% evenly between enchanted rings.",
          "valueOptions": {
            "sourceType": "ModSettingInt",
            "defaultValue": 0,
            "options": [
              "Full strength",
              "Fixed strength",
              "Split strength"
            ]
          }
        },
        {
          "id": "iFixedEnchantmentStrengthPercent:General",
          "text": "Fixed strength",
          "type": "slider",
          "groupCondition": 1,
          "groupBehavior": "hide",
          "help": "All equipped enchanted rings use this strength.",
          "valueOptions": {
            "sourceType": "ModSettingInt",
            "defaultValue": 50,
            "min": 5,
            "max": 100,
            "step": 5,
            "formatString": "{0}%"
          }
        },
        {
          "id": "bAlwaysChooseFinger:General",
          "text": "Always choose finger",
          "type": "toggle",
          "help": "Show the finger selection menu whenever you use Equip or Left Equip on a ring.",
          "valueOptions": {
            "sourceType": "ModSettingBool",
            "defaultValue": false
          }
        }
      ]
    }
  ]
}
